// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRESQL_URI")
}

model User {
  id        String   @id @unique @default(uuid())
  email     String   @unique
  name      String
  avatar    String?
  status    Status   @default(OFFLINE)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contacts      Contact[]       @relation("UserContact")
  Conversations Conversations[] @relation("participants conversation")
  Message       Message[]       @relation("sender")
}

model Contact {
  id    String @id @unique @default(uuid())
  name  String
  email String @unique

  user   User   @relation("UserContact", fields: [userId], references: [id])
  userId String
}

model Conversations {
  id String @id @unique @default(uuid())

  participants User[]    @relation("participants conversation")
  Message      Message[] @relation("messages")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Message {
  id      String @id @unique @default(uuid())
  content String

  sender          User          @relation("sender", fields: [senderId], references: [id])
  senderId        String
  conversation    Conversations @relation("messages", fields: [conversationsId], references: [id])
  conversationsId String

  // reply     Message?  @relation("reply", fields: [replyId], references: [id])
  // replyId   String?
  // replyedAt Message[] @relation("reply")

  reply Reply @relation(fields: [replyId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  replyId   String
}

model Reply {
  id        String    @id @unique @default(uuid())
  messageId String
  Message   Message[]
}

enum Status {
  ONLINE
  OFFLINE
  OFF
}
